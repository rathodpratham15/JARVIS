{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip3 install -r requirements.txt && pip3 install -e ."
  },
  "deploy": {
    "startCommand": "gunicorn --bind 0.0.0.0:$PORT --worker-class eventlet -w 1 --timeout 120 wsgi:app",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
