# J.A.R.V.I.S v2 — copy this file to .env and fill in real values.

# ── LLM provider ─────────────────────────────────────────────────────
# Pick which API powers free-form chat and Whisper transcription.
# Leave unset for auto-detect (uses whichever key below is set).
# JARVIS_LLM_PROVIDER=openai     # openai | groq
# JARVIS_STT_PROVIDER=groq       # ditto, separate so chat and STT can differ
# JARVIS_LLM_MODEL=gpt-4         # provider-specific. defaults: openai→gpt-4, groq→llama-3.3-70b-versatile
# JARVIS_STT_MODEL=whisper-1     # defaults: openai→whisper-1, groq→whisper-large-v3

# OpenAI (https://platform.openai.com/api-keys).
OPENAI_API_KEY=

# Groq (https://console.groq.com/keys). Generous free tier; OpenAI-compatible API.
GROQ_API_KEY=

# Optional — real-time weather. Either provider works.
# https://openweathermap.org/api
OPENWEATHER_API_KEY=
# https://www.weatherapi.com/
WEATHER_API_KEY=

# Optional — scene analysis (POST /api/vision/analyze).
# Either provider works; Gemini is preferred if both are set.
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# (or set GOOGLE_API_KEY — both work)

# Optional — face DB tuning.
# JARVIS_FACE_DIR=data/faces
# JARVIS_FACE_TOLERANCE=0.5

# Optional — memory database path. Defaults to data/memory.db.
# JARVIS_DB=data/memory.db

# Optional — Smart home via Home Assistant REST API.
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=<long-lived access token from HA Profile page>

# Optional — CORS allowlist for the Flask web app. Defaults to *.
# CORS_ORIGINS=https://yourapp.example
